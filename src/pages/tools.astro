---
import Base from '../layouts/Base.astro';
const tools = [
  {
    category: "AI Coding Tools",
    items: [
      { name: "Cursor IDE", desc: "AI-powered code editor with intelligent suggestions and chat assistance. Built for modern development.", url: "https://cursor.sh", badge: "Editor's Pick" },
      { name: "GitHub Copilot", desc: "Your AI pair programmer that suggests code completions and entire functions in real-time.", url: "https://github.com/features/copilot", badge: "Popular" },
      { name: "Claude Code", desc: "AI assistant for coding tasks with excellent context understanding and code generation.", url: "https://claude.ai/code", badge: null },
    ]
  },
  {
    category: "Development Tools",
    items: [
      { name: "Visual Studio Code", desc: "Free code editor with massive extension ecosystem. Perfect for web development.", url: "https://code.visualstudio.com", badge: "Free" },
      { name: "GitKraken", desc: "Beautiful Git GUI client that makes version control visual and intuitive.", url: "https://www.gitkraken.com", badge: null },
      { name: "Postman", desc: "API development environment with testing, documentation, and collaboration features.", url: "https://www.postman.com", badge: "Freemium" },
    ]
  },
  {
    category: "Hosting & Deployment",
    items: [
      { name: "Cloudflare Pages", desc: "Free hosting with global CDN. Perfect for static sites and blogs.", url: "https://pages.cloudflare.com", badge: "Free" },
      { name: "Vercel", desc: "Deploy and host web apps with zero config. Excellent for Next.js and React.", url: "https://vercel.com", badge: "Freemium" },
      { name: "Railway", desc: "Simple deployment platform that takes your code from repo to production in minutes.", url: "https://railway.app", badge: null },
      { name: "DigitalOcean", desc: "Reliable cloud infrastructure with simple pricing and great developer experience.", url: "https://www.digitalocean.com", badge: null },
    ]
  },
  {
    category: "Domains & DNS",
    items: [
      { name: "Cloudflare Registrar", desc: "Best domain registrar at cost price. No markup fees, ever.", url: "https://cloudflare.com/registrar", badge: "Best Value" },
      { name: "Namecheap", desc: "Affordable domain registration with free WHOIS privacy protection.", url: "https://www.namecheap.com", badge: null },
    ]
  },
  {
    category: "Backend & Database",
    items: [
      { name: "Supabase", desc: "Open source Firebase alternative with PostgreSQL, auth, and storage.", url: "https://supabase.com", badge: "Open Source" },
      { name: "PlanetScale", desc: "MySQL-compatible database serverless platform with branching and scaling.", url: "https://planetscale.com", badge: "Freemium" },
      { name: "MongoDB Atlas", desc: "Fully managed cloud database with automatic scaling and global distribution.", url: "https://www.mongodb.com/cloud/atlas", badge: null },
    ]
  },
  {
    category: "AI Writing & Content",
    items: [
      { name: "ChatGPT Plus", desc: "Advanced AI assistant for writing, brainstorming, and content creation.", url: "https://chat.openai.com", badge: "Popular" },
      { name: "Claude Pro", desc: "AI assistant with excellent writing capabilities and longer context windows.", url: "https://claude.ai", badge: null },
      { name: "Jasper", desc: "AI writing platform specialized for marketing content and blog posts.", url: "https://www.jasper.ai", badge: "Premium" },
    ]
  },
  {
    category: "Design & UI",
    items: [
      { name: "Figma", desc: "Collaborative design tool with powerful features for UI/UX design.", url: "https://www.figma.com", badge: "Free" },
      { name: "Tailwind CSS", desc: "Utility-first CSS framework for rapid custom design development.", url: "https://tailwindcss.com", badge: "Free" },
      { name: "Unsplash", desc: "Beautiful, free stock photos for your blog and website projects.", url: "https://unsplash.com", badge: "Free" },
    ]
  },
  {
    category: "Analytics & SEO",
    items: [
      { name: "Google Analytics", desc: "Free web analytics service to track and report website traffic.", url: "https://analytics.google.com", badge: "Free" },
      { name: "Google Search Console", desc: "Free tool to monitor and maintain your site's presence in Google search results.", url: "https://search.google.com/search-console", badge: "Free" },
      { name: "Ahrefs", desc: "Comprehensive SEO toolset for keyword research, backlink analysis, and rank tracking.", url: "https://ahrefs.com", badge: "Premium" },
    ]
  },
];
---
<Base title="Tools" description="Tools and resources recommended by Naresh — some are affiliate links.">
  <section class="tools-container">
    <div class="tools-header">
      <h1 class="tools-title">Recommended Tools</h1>
      <p class="tools-sub">
        Tools I personally use and recommend. Some links are affiliate links — they cost you nothing extra and help support this blog.
      </p>
    </div>

    <div class="ad-unit">📢 Advertisement — AdSense unit goes here</div>

    {tools.map(section => (
      <div class="tools-section">
        <h2 class="category-title">{section.category}</h2>
        <div class="tools-grid">
          {section.items.map(tool => (
            <a href={tool.url} class="tool-card" target="_blank" rel="noopener noreferrer nofollow">
              <div class="tool-top">
                <span class="tool-name">{tool.name}</span>
                {tool.badge && <span class="tool-badge">{tool.badge}</span>}
              </div>
              <p class="tool-desc">{tool.desc}</p>
              <span class="tool-link">Visit site →</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</Base>

<style>
  .tools-container { max-width: 900px; margin: 0 auto; padding: 4rem 1.5rem; }
  .tools-header { margin-bottom: 2.5rem; }
  .tools-title { font-size: 2.2rem; font-weight: 800; letter-spacing: -0.03em; }
  .tools-sub { color: var(--muted); margin-top: 0.5rem; font-size: 0.9rem; max-width: 500px; }
  .tools-section { margin-bottom: 3rem; }
  .category-title { font-size: 1.1rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem; }
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
  .tool-card {
    display: flex; flex-direction: column; gap: 0.5rem;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; padding: 1.25rem;
    text-decoration: none; transition: border-color 0.2s, transform 0.2s;
  }
  .tool-card:hover { border-color: var(--accent); transform: translateY(-2px); text-decoration: none; }
  .tool-top { display: flex; justify-content: space-between; align-items: center; }
  .tool-name { color: var(--text); font-weight: 700; font-size: 0.95rem; }
  .tool-badge {
    background: rgba(9,105,218,0.08); color: var(--accent);
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.15rem 0.55rem; border-radius: 999px;
  }
  .tool-desc { color: var(--muted); font-size: 0.82rem; line-height: 1.4; flex: 1; }
  .tool-link { color: var(--accent); font-size: 0.8rem; font-weight: 600; margin-top: auto; }
</style>
